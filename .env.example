# Phone theke access: same WiFi, HOST=0.0.0.0 (default)
HOST=0.0.0.0
PORT=5000

# Admin password (secret) — set your own value
ADMIN_PIN=
ENTRY_FEE=25
BKASH_NUMBER=01822777137
NAGAD_NUMBER=01822777137

# Payment provider: auto | rupantorpay | bkash | sslcommerz
PAYMENT_PROVIDER=auto

# Gateway payment success hole auto approve (manual payment e admin approve thakbe)
# 1 = ON, 0 = OFF
AUTO_APPROVE_GATEWAY=0

# RupantorPay — https://rupantorpay.com/user/dashboard → Brands → API key
RUPANTORPAY_API_KEY=
RUPANTORPAY_CLIENT=127.0.0.1

# bKash Checkout (URL based)
# You will get these from bKash onboarding / merchant portal
# BKASH_BASE_URL example (sandbox): https://checkout.sandbox.bka.sh/v1.2.0-beta
BKASH_BASE_URL=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=

# Live hosting URL (Render deploy er por)
# PUBLIC_BASE_URL=https://ff-tournament.onrender.com

# Production (Render Environment e add koro)
# SECRET_KEY=random-long-string-here

# SSLCommerz (optional, Rupantor na thakle use hoy)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_IS_LIVE=0

# UID API — infoapiuid (default)
# GET https://infoapiuid.vercel.app/bd/{UID}
# GET https://infoapiuid.vercel.app/pk/{UID}
FF_API_BASE=https://infoapiuid.vercel.app
FF_SERVER=bd
# Backup APIs
FF_API_FLAME_BASE=https://apiinfo-flame.vercel.app
FF_API_LEGACY_BASE=https://freefire-api-six.vercel.app

# Optional custom API (set korle built-in off)
# FF_UID_API_URL=https://other-api.com/player?uid={uid}
# FF_UID_API_MOCK=0

